# OrbitalRates — Environment Configuration
# Copy this file to .env and customize

# ── General ──────────────────────────────────────
ORBITAL_ENV=development
ORBITAL_DEBUG=true

# ── Risk Hard Constraints ────────────────────────
ORBITAL_MAX_DRAWDOWN_PCT=8.0
ORBITAL_MAX_SINGLE_EVENT_LOSS_PCT=3.0
ORBITAL_SURVIVAL_PROBABILITY_MIN=0.99
ORBITAL_TARGET_SHARPE=1.5
ORBITAL_MAX_LEVERAGE=10.0

# ── Spread Discovery ────────────────────────────
ORBITAL_ZSCORE_ENTRY_THRESHOLD=2.0
ORBITAL_MIN_HALFLIFE_DAYS=5
ORBITAL_MAX_HALFLIFE_DAYS=90
ORBITAL_ADF_PVALUE_THRESHOLD=0.05

# ── Kelly Fraction ──────────────────────────────
ORBITAL_KELLY_FRACTION_MIN=0.2
ORBITAL_KELLY_FRACTION_MAX=0.4
ORBITAL_KELLY_FRACTION_DEFAULT=0.3

# ── Frontend ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
